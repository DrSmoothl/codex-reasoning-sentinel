{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/scripts/reasoning_guard.py",
            "statusMessage": "Reasoning Guard: loading session guardrails"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/scripts/reasoning_guard.py",
            "statusMessage": "Reasoning Guard: checking prompt risk"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/scripts/reasoning_guard.py",
            "statusMessage": "Reasoning Guard: preparing subagent guardrails"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/scripts/reasoning_guard.py",
            "statusMessage": "Reasoning Guard: checking subagent reasoning tokens"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/scripts/reasoning_guard.py",
            "statusMessage": "Reasoning Guard: checking reasoning tokens"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/scripts/reasoning_guard.py",
            "statusMessage": "Reasoning Guard: checking risky tool use"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/scripts/reasoning_guard.py",
            "statusMessage": "Reasoning Guard: checking approval request"
          }
        ]
      }
    ]
  }
}
